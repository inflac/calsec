{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run calsec",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["${workspaceFolder}/gui/main.py"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Run tests",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["-m", "pytest", "tests/", "-v"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Run tests with coverage",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["-m", "pytest", "tests/", "-v", "--cov=gui", "--cov-report=term-missing", "--cov-report=html:coverage_html"],
      "group": "test",
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Clean build",
      "type": "shell",
      "command": "& { Remove-Item -Recurse -Force -ErrorAction SilentlyContinue build/work; Remove-Item -Force -ErrorAction SilentlyContinue build/calsec.exe }",
      "args": [],
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "Build binary",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "-m", "PyInstaller",
        "--onefile",
        "--name", "calsec",
        "--noconsole",
        "--icon", "${workspaceFolder}/icon.ico",
        "--add-data", "${workspaceFolder}/icon.ico:.",
        "--collect-all", "cryptography",
        "--distpath", "build",
        "--workpath", "build/work",
        "--specpath", "build/spec",
        "gui/main.py"
      ],
      "dependsOn": ["Clean build"],
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Build & Package",
      "type": "shell",
      "command": "Compress-Archive",
      "args": [
        "-Force",
        "-Path", "build/calsec,icon.png,calsec.desktop,install_calsec.sh",
        "-DestinationPath", "calsec.zip"
      ],
      "dependsOn": ["Build binary"],
      "group": "build",
      "presentation": {
        "reveal": "always"
      }
    }
  ]
}
